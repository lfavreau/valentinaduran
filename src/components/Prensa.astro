---
const prensa = [
  {
    date: 'Octubre 2025',
    outlet: 'Periodico Resumen',
    title: 'Dramaturga de Hora de Colacion: el teatro es importante como un lugar de presencia y encuentro',
    url: 'https://resumen.cl/articulos/dramaturga-de-hora-de-colacion-el-teatro-es-importante-como-un-lugar-de-presencia-y-encuentro-ante-un-mundo-digital-que-no-distingue-profundidades',
  },
  {
    date: 'Octubre 2024',
    outlet: 'Revista Digital Descentrados',
    title: 'Yo no canto por cantar: resistencia, sentido y razon del sector cultural',
    url: 'https://descentrados.cl/disfrutarte/yo-no-canto-por-cantar-resistencia-sentido-y-razon-del-sector-cultural/',
  },
  {
    date: 'Enero 2019',
    outlet: 'Revista Culturizarte',
    title: 'Entrevista a Valentina Duran sobre Campo de Batalla. Las Ruinas de Estocolmo',
    url: 'https://culturizarte.cl/entrevista-a-la-directora-de-campo-de-batalla-las-ruinas-de-estocolmo-valentina-duran-los-temas-de-los-que-trata-la-obra-son-bien-contingentes/',
  },
  {
    date: 'Marzo 2019',
    outlet: 'Diario Concepcion',
    title: 'Valentina Duran, actriz y dramaturga: el desafio es la equidad, no solo de genero',
    url: 'https://www.diarioconcepcion.cl/cultura-y-espectaculos/2019/05/26/valentina-duran-actriz-y-dramaturga-el-desafio-es-la-equidad-no-solo-de-genero.html',
  },
  {
    date: 'Septiembre 2019',
    outlet: 'Diario Concepcion',
    title: 'Mi lado deportivo: Valentina Duran, actriz y directora Sidarte filial Bio Bio',
    url: 'https://www.diarioconcepcion.cl/deportes/2019/09/02/mi-lado-deportivo-valentina-duran-actriz-y-directora-sidarte-filial-bio-bio.html',
  },
];
---

<section id="prensa" class="section prensa-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label reveal">Archivo y Medios</span>
      <h2 class="section-title reveal">Prensa</h2>
      <p class="section-subtitle reveal">
        Entrevistas, publicaciones y registros sobre el trabajo escenico y cultural
      </p>
    </div>

    <div class="prensa-list stagger">
      {prensa.map((item) => (
        <a class="prensa-item reveal" href={item.url} target="_blank" rel="noopener noreferrer">
          <span class="prensa-meta">
            <span>{item.date}</span>
            <span class="prensa-dot">·</span>
            <span>{item.outlet}</span>
          </span>
          <span class="prensa-title">{item.title}</span>
          <span class="prensa-action">Leer publicacion</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .prensa-section {
    background: var(--bg-primary);
  }

  .prensa-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 920px;
    margin: 0 auto;
  }

  .prensa-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px 28px;
    align-items: center;
    padding: 26px 28px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color 0.3s ease, background 0.3s ease, transform 0.3s ease;
  }

  .prensa-item:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-medium);
    transform: translateY(-2px);
  }

  .prensa-meta {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .prensa-dot {
    color: var(--accent);
  }

  .prensa-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    line-height: 1.2;
    color: var(--text-primary);
    transition: color 0.3s ease;
  }

  .prensa-item:hover .prensa-title {
    color: var(--accent);
  }

  .prensa-action {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .prensa-item {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 22px;
    }

    .prensa-action {
      white-space: normal;
    }
  }
</style>
