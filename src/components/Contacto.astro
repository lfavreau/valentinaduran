---

<section id="contacto" class="section contacto">
  <div class="container">
    <div class="section-header">
      <span class="section-label reveal">Hablemos</span>
      <h2 class="section-title reveal">Contacto</h2>
      <p class="section-subtitle reveal">
        ¿Tienes un proyecto en mente? Nos encantaría escucharte
      </p>
    </div>

    <div class="contacto-grid">
      <div class="contacto-info reveal-left">

      
        <div class="info-block" style="margin-top: -16px; margin-bottom: 32px;">
          <button id="modal-trigger" class="info-link-btn">
            Actividades Teatrales, Escénicas, Artísticas y Culturales<br>Valentina Durán EIRL.
          </button>
        </div>

        
        <div class="info-block">
          <h3 class="info-title">Correo Electrónico</h3>
          <a href="mailto:valentinaduranb@gmail.com" class="info-link glow-line">
            valentinaduranb@gmail.com
          </a>
        </div>


        <div class="info-block">
          <h3 class="info-title">Whatsapp</h3>
          <a href="https://wa.me/56978639138" class="info-link glow-line" target="_blank" rel="noopener noreferrer">
            +56 9 7863 9138
          </a>
        </div>

        <div class="social-links">
          <a href="#" class="social-link" aria-label="Instagram" title="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="17.5" cy="6.5" r="1.5"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Facebook" title="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="YouTube" title="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/>
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
            </svg>
          </a>
        </div>
      </div>

      <form action="https://formspree.io/f/mnjglqoo" method="POST" class="contacto-form reveal-right" id="contact-form">
        <div class="form-group">
          <label for="name" class="form-label">Nombre</label>
          <input type="text" id="name" name="name" class="form-input" required placeholder="Tu nombre" />
        </div>
        <div class="form-group">
          <label for="email" class="form-label">Email</label>
          <input type="email" id="email" name="email" class="form-input" required placeholder="tu@email.com" />
        </div>
        <div class="form-group">
          <label for="subject" class="form-label">Asunto</label>
          <input type="text" id="subject" name="subject" class="form-input" placeholder="¿En qué podemos ayudarte?" />
        </div>
        <div class="form-group">
          <label for="message" class="form-label">Mensaje</label>
          <textarea id="message" name="message" class="form-input form-textarea" required rows="5" placeholder="Cuéntanos sobre tu proyecto..."></textarea>
        </div>
        <button type="submit" class="btn form-btn">
          <span class="btn-text">Enviar Mensaje</span>
          <span class="btn-arrow">→</span>
        </button>
        <div id="form-status" class="form-status"></div>
      </form>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="divider" style="margin-bottom: 32px;"></div>
      <div class="footer-inner">
        <p class="footer-brand">Valentina Durán. Actriz, Pedagoga Teatral & Directora.</p>
        <p class="footer-copy">© 2026 Valentina Durán. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>
</section>

<!-- Modal Empresa -->
<div id="company-modal" class="vd-modal" aria-hidden="true">
  <div class="vd-modal-overlay"></div>
  <div class="vd-modal-content">
    <button class="vd-modal-close" id="modal-close" aria-label="Cerrar modal">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="vd-modal-header">
      <h2 class="vd-modal-title">Actividades Teatrales, Escénicas, Artísticas y Culturales<br>Valentina Durán EIRL.</h2>
    </div>
    <div class="vd-modal-body">
      <p>
        Empresa de servicios culturales creada el 2024 para formalizar el trabajo artístico y cultural de su representante Valentina Durán, de la compañía Teatrhoy y de su entorno laboral. Cuenta con 20 años de experiencia en la gestión cultural y las Artes Escénicas en la región del Biobío, ofreciendo servicios artísticos y culturales, así como de enseñanza artística y cultural en diversos organismos como universidades, instituciones públicas y privadas, y centros culturales. 
      </p>
      <p>
        Dentro de su servicios se encuentran Obras de Teatro de creación propia, a pedido, intervenciones, recreaciones históricas, ramos, cursos y talleres, además del área de la gestión cultural y producción escénica, artística y cultural. Su representante ha sido gestora de espacios culturales en la región como Del Aire Artería (2010- 2013) con programación mensual de obras de teatro y exposiciones de artes visuales, coordinadora de programas de alcance regional como Patios Culturales en el 2023, durante 7 años dirigió el Circuito de Recreaciones Históricas del Biobío (Nacimiento, Concepción, Talcahuano, Penco, Portezuelo), y desde hace 15 años hasta la fecha trabaja en el Festival Internacional de Teatro del Biobío en donde actualmente es Coordinadora de Vinculación y Territorio. 
      </p>
      <p>
        Desde febrero del 2025 está a cargo de la Sala Namaste (espacio de desarrollo personal, artístico y cultural), en donde realiza talleres para diferentes públicos en Concepción. Con esta personalidad jurídica ha podido generar ventas de obras, circulación por la región, talleres trimetrales, mensuales y clases abiertas.
      </p>
    </div>
  </div>
</div>

<style>
  .contacto {
    background: var(--bg-secondary);
    padding-bottom: 0;
  }

  .contacto-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  .info-block {
    margin-bottom: 32px;
  }

  .info-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .info-link {
    display: inline-block;
    font-size: 1rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding-bottom: 2px;
    transition: color 0.3s ease;
  }

  .info-link:hover {
    color: var(--accent);
  }

  .info-text {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .social-links {
    display: flex;
    gap: 16px;
    margin-top: 8px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-muted);
    transition: color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .social-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  /* Form Styles */
  .contacto-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .form-input {
    width: 100%;
    padding: 14px 16px;
    background: var(--bg-primary);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 300;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    outline: none;
  }

  .form-input::placeholder {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .form-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-btn {
    align-self: flex-start;
    margin-top: 8px;
      position: relative;
    }

    .form-status {
      margin-top: 15px;
      font-size: 0.9rem;
      padding: 10px;
      display: none;
      border-radius: 4px;
    }
    .form-status.success {
      display: block;
      background: rgba(0, 255, 100, 0.1);
      color: #4ade80;
    }
    .form-status.error {
      display: block;
      background: rgba(255, 0, 0, 0.1);
      color: #f87171;
  }

  .btn-arrow {
    transition: transform 0.3s ease;
  }

  .form-btn:hover .btn-arrow {
    transform: translateX(4px);
  }

  /* Footer */
  .footer {
    margin-top: var(--section-padding);
    padding: 0 0 32px;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--accent);
    opacity: 0.6;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .contacto-grid {
      grid-template-columns: 1fr;
    }

    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }

  /* Button Link Override */
  .info-link-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-muted);
    text-align: left;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: rgba(157, 125, 197, 0.3);
    transition: color 0.3s ease, text-decoration-color 0.3s ease;
    line-height: 1.4;
  }
  .info-link-btn:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
</style>

<style is:global>
  /* Modal Styles Global */
  .vd-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .vd-modal.active {
    opacity: 1;
    pointer-events: auto;
  }

  .vd-modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
  }

  .vd-modal-content {
    position: relative;
    width: 90%;
    max-width: 800px;
    max-height: 85vh;
    background: var(--bg-card);
    border: 1px solid var(--border-medium);
    padding: clamp(30px, 5vw, 60px);
    overflow-y: auto;
    transform: translateY(20px);
    transition: transform 0.4s var(--ease-out-expo);
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.6);
  }

  .vd-modal.active .vd-modal-content {
    transform: translateY(0);
  }

  .vd-modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.3s ease, transform 0.3s ease;
    z-index: 10;
  }

  .vd-modal-close:hover {
    color: var(--accent);
    transform: rotate(90deg);
  }

  .vd-modal-title {
    margin-bottom: 24px;
    padding-right: 40px;
    line-height: 1.3;
    color: var(--accent);
    font-family: var(--font-display);
    font-size: 1.6rem;
  }

  .vd-modal-body p {
    margin-bottom: 20px;
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1rem;
    font-family: var(--font-body);
    text-align: justify;
  }

  .vd-modal-body p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .vd-modal-content {
      padding: 40px 24px;
      width: 95%;
    }
    .vd-modal-title {
      font-size: 1.3rem;
    }
  }
</style>

<script>
  const trigger = document.getElementById('modal-trigger');
  const modal = document.getElementById('company-modal');
  const closeBtn = document.getElementById('modal-close');
  const overlay = modal?.querySelector('.vd-modal-overlay');

  const openModal = () => {
    if (modal) {
      modal.classList.add('active');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
  };

  const closeModal = () => {
    if (modal) {
      modal.classList.remove('active');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  };

  trigger?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', closeModal);

  // Close on Escape key
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('active')) {
      closeModal();
    }
  });

  // Manejo del formulario con Formspree (AJAX para no recargar la página)
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status || !form) return;

    const data = new FormData(form);
    try {
      const response = await fetch(form.action, {
        method: form.method,
        body: data,
        headers: {
          'Accept': 'application/json'
        }
      });
      
      if (response.ok) {
        status.innerHTML = "¡Gracias! Tu mensaje ha sido enviado correctamente.";
        status.className = "form-status success";
        form.reset();
      } else {
        const result = await response.json();
        status.innerHTML = result.errors ? result.errors.map((error: any) => error.message).join(", ") : "Hubo un problema al enviar el formulario.";
        status.className = "form-status error";
      }
    } catch (error) {
      status.innerHTML = "Error de conexión. Inténtalo más tarde.";
      status.className = "form-status error";
    }
  });
</script>
